LABEL ArchR
  LINUX /KERNEL
  FDTDIR /dtbs/
  FDTOVERLAYS /overlays/mipi-panel.dtbo
  APPEND boot=${partition_boot} root=${partition_root} rw rootwait disk=${partition_storage} console=ttyS2,1500000 console=tty0 loglevel=7 systemd.show_status=true vt.global_cursor_default=0 consoleblank=0 net.ifnames=0 mitigations=off audit=0 nowatchdog threadirqs zswap.enabled=0 loop.max_loop=16 uboot.hwid_adc=${hwid_adc}
