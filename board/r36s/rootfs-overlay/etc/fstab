# /etc/fstab — R36S CyberDeck OS minimal rootfs (Fase 2)
# A raiz (/) é montada pelo kernel via root=UUID=... no boot.ini.
# Aqui ficam apenas os pseudo-filesystems (rcS também os monta).
proc     /proc     proc     defaults   0 0
sysfs    /sys      sysfs    defaults   0 0
devtmpfs /dev      devtmpfs defaults   0 0
devpts   /dev/pts  devpts   defaults   0 0
tmpfs    /run      tmpfs    defaults   0 0
