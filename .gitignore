# Montagens locais da imagem ArkOS (nunca versionar)
/mnt/

# Artefatos extraídos do ArkOS:
#  - texto (boot.ini, *.dts, relatórios) É versionado — referência de hardware.
#  - binários grandes (kernel Image, uInitrd, *.dtb) NÃO são versionados
#    (regeráveis via scripts/extract-arkos-boot-artifacts.sh).
/artifacts/arkos-reference/kernel/Image
/artifacts/arkos-reference/kernel/uInitrd
/artifacts/arkos-reference/kernel/zImage
# Blobs proprietários da Mali — NÃO redistribuir; regeráveis via
# experiments/extract-arkos-mali.sh a partir do ArkOS do próprio usuário.
/artifacts/arkos-reference/mali/

# Imagens de SD / kernels / dtbs soltos
*.img
*.img.gz
*.img.xz
*.xz
*.dtb
Image
zImage
uInitrd
initrd.img*

# Imagens de teste (Fase 2): build/ e .img são regeráveis; reports/ é versionado
/artifacts/test-images/build/
/artifacts/test-images/*.img
!/artifacts/test-images/reports/

# Screenshots recuperados do cartão (sd-get-screenshots.sh) — capturas locais
/artifacts/screenshots/

# Renderizador de framebuffer: binário compilado (regerável via build.sh)
/cyberdeck-fb/build/

# Binários compilados (regeráveis via build.sh de cada um)
/experiments/cyberdeck-input/cyberdeck-input
/experiments/cyberdeck-agent-c/cyberdeck-agent
/cyberdeck-fb/cyberdeck-fb

# Fase 5: artefatos mainline grandes (imagem Arch-R, kernel, módulos). Texto versionado.
/artifacts/mainline/*.img
/artifacts/mainline/*.img.gz
/artifacts/mainline/Image
/artifacts/mainline/modules/
/artifacts/mainline/*.ext4
!/artifacts/mainline/reports/

# Buildroot output
/buildroot/output/
/buildroot/dl/

# Node / UI
node_modules/
dist/

# Loop device record
.loopdev

# Editores / SO
*.swp
.DS_Store

# Allowlist de cartões SD (identidade de hardware local)
/scripts/sdcard/authorized-cards.tsv
/scripts/sdcard/images.tsv
/scripts/sdcard/bindings.tsv
/artifacts/mainline/custom-dtb/
